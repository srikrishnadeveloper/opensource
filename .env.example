# Copy to .env and fill in values. Never commit .env.

# --- Wiki paths (local dev) ---
WIKI_BRAIN_DIR=

# --- MCP transport ---
# stdio = Cursor / Claude Desktop (default)
# streamable-http = Render / ChatGPT connector
MCP_TRANSPORT=stdio
PORT=8000

# --- Cloud smoke tests (optional local scripts) ---
MCP_TEST_URL=https://your-service.onrender.com

# --- Cloud auth (required on Render) ---
MCP_API_KEY=

# --- GitHub writes (optional — enables create_page, update_page, delete_page) ---
# Fine-grained PAT: Contents read+write on YOUR fork only
# https://github.com/settings/tokens?type=beta
#
# On Render: only GITHUB_TOKEN is required — repo/branch are auto-detected.
# Locally: set GITHUB_REPO if not using Render.
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=

# --- Local dev only ---
WIKI_AUTO_PULL=0
WIKI_DISABLE_REDACTION=0
