# Copy to .env and fill in values. Never commit .env.

# --- Wiki paths (local dev) ---
WIKI_BRAIN_DIR=

# --- MCP transport ---
# stdio = Cursor / Claude Desktop (default)
# streamable-http = Render / ChatGPT connector
MCP_TRANSPORT=stdio
PORT=8000

# --- Cloud smoke tests (optional local scripts) ---
MCP_TEST_URL=https://your-service.onrender.com

# --- Cloud auth (required on Render) ---
MCP_API_KEY=

# --- GitHub writes (optional — enables create_page, update_page, delete_page) ---
# Fine-grained PAT: Contents read+write on YOUR fork only
# https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=
GITHUB_REPO=your-org/wiki-brain
GITHUB_BRANCH=main

# --- Notion mirror (optional — wiki pages also show up in Notion) ---
# Create an integration at https://www.notion.so/my-integrations, share a page
# with it, then run: python mcp-server/notion_sync.py setup
NOTION_TOKEN=
NOTION_DATABASE_ID=
# Only needed the first time you run `setup` (the workspace page that will hold
# the auto-created "Wiki Brain" database):
NOTION_PARENT_PAGE_ID=

# --- Local dev only ---
WIKI_AUTO_PULL=0
WIKI_DISABLE_REDACTION=0
